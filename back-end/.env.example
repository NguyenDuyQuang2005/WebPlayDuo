# Sao chép thành file `.env` và điền giá trị thật.

# Chuỗi kết nối MongoDB (MongoDB Atlas hoặc local)
MONGODB_CONNECTION_STRING=mongodb://127.0.0.1:27017/playerduo

# Dùng để ký JWT access token — đặt chuỗi dài ngẫu nhiên
ACCESS_TOKEN_SECRET=thay-bang-chuoi-bi-mat-rat-dai

PORT=5001
NODE_ENV=development

# Gốc front-end (CORS). Dev: thêm cả 127.0.0.1 nếu mở app bằng IP.
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Tài khoản admin (chọn một trong hai cách) ---
#
# Cách A — Đã có user: chỉ cần email đã đăng ký → mỗi lần start server sẽ gán role admin.
# BOOTSTRAP_ADMIN_EMAIL=ban@example.com
#
# Cách B — Tạo admin mới lần đầu (chưa có email trong DB): thêm username + mật khẩu (≥6 ký tự).
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=dat-mat-khau-manh-o-day
# BOOTSTRAP_ADMIN_DISPLAY_NAME=Quản trị viên

